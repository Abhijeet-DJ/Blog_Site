# Database — set DB_DRIVER to the adapter you want to use
# Supported: mongodb
DB_DRIVER=mongodb
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/daisy-blog?retryWrites=true&w=majority

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
